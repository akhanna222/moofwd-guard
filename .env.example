# MoofwdGuard Environment Configuration

# Mastercard MPGS
MPGS_BASE_URL=https://test-gateway.mastercard.com
MPGS_MERCHANT_ID=your_merchant_id
MPGS_API_KEY=your_mpgs_api_key

# IPQS (IP Quality Score)
IPQS_API_KEY=your_ipqs_api_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://moofwd:moofwd@postgres:5432/moofwdguard
POSTGRES_DB=moofwdguard
POSTGRES_USER=moofwd
POSTGRES_PASSWORD=moofwd

# Decision thresholds
DECISION_APPROVE_THRESHOLD=30.0
DECISION_DECLINE_THRESHOLD=65.0
